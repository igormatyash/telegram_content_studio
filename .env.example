# Create a fresh token after revoking any token shared in a chat or screenshot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=@voicerhub
PRODUCT_NAME=Content Studio

# Send /id to the bot, then place your numeric Telegram user ID here.
# Multiple editors can be comma-separated.
ADMIN_USER_IDS=

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
USE_IMAGE_BATCH=true

# Batch prices per 1M tokens. Verify against your OpenAI account pricing.
TEXT_BATCH_INPUT_PRICE_PER_1M=0.75
TEXT_BATCH_OUTPUT_PRICE_PER_1M=4.50
TEXT_STANDARD_INPUT_PRICE_PER_1M=1.50
TEXT_STANDARD_OUTPUT_PRICE_PER_1M=9.00
# gpt-image-1.5, medium, 1536x1024. Batch is 50% below standard.
IMAGE_BATCH_PRICE_PER_GENERATION=0.025
IMAGE_STANDARD_PRICE_PER_GENERATION=0.05

DATABASE_PATH=data/voicerhub_bot.sqlite3
GENERATED_DIR=data/generated
REFERENCE_DIR=data/references

# Optional transparent PNG logo. If omitted, a clean VOICERHUB wordmark is rendered.
BRAND_LOGO_PATH=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Set true only after the admin panel is served over HTTPS.
SESSION_COOKIE_SECURE=false
ADMIN_BASE_PATH=/content-admin
PUBLIC_APP_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Random secret used only to hash IP addresses in analytics/referral events.
PRIVACY_HASH_SALT=

# Generate once with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
ORGANIZATIONS_DIR=data/organizations
MAX_ORGANIZATIONS=10000
DEFAULT_MAX_USERS=50
DEFAULT_MAX_CHANNELS=1
DEFAULT_MONTHLY_PUBLICATIONS=90
DEFAULT_MONTHLY_AI_BUDGET=50
